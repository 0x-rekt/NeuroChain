{
  "manifest_version": 3,
  "name": "NeuroChain Meet Extractor",
  "version": "1.0",
  "description": "Live AI knowledge extraction from Google Meet to NeuroChain via Algorand.",
  "permissions": [
    "storage",
    "activeTab",
    "scripting"
  ],
  "host_permissions": [
    "https://meet.google.com/*",
    "http://localhost:3000/*",
    "http://localhost:8000/*"
  ],
  "background": {
    "service_worker": "background.js"
  },
  "action": {
    "default_popup": "popup.html",
    "default_icon": "icon.png"
  },
  "content_scripts": [
    {
      "matches": [
        "https://meet.google.com/*",
        "http://localhost:3000/*"
      ],
      "js": ["content.js"],
      "run_at": "document_end"
    }
  ]
}